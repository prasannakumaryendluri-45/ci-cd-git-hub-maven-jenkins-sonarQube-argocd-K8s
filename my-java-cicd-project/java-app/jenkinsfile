pipeline {
    agent {
        docker {
            image 'maven:3.9.5-jdk-21'
            args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    environment {
        DOCKER_IMAGE = "prasannakumaryendluri45/app:${BUILD_NUMBER}"
        SONAR_URL = "http://98.94.75.129:9000"
        GIT_REPO_NAME = "ci-cd-git-hub-maven-jenkins-sonarQube-argocd-K8s"
        GIT_USER_NAME = "prasannakumaryendluri-45"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/prasannakumaryendluri-45/ci-cd-git-hub-maven-jenkins-sonarQube-argocd-K8s.git'
            }
        }

        stage('Build and Test') {
            steps {
                script {
                    def appDir = "${WORKSPACE}/my-java-cicd-project/java-app"
                    if (fileExists("${appDir}/pom.xml")) {
                        sh """
                            echo "Building Java project in ${appDir}"
                            cd ${appDir}
                            java -version
                            mvn -version
                            mvn clean package -B -e
                        """
                    } else {
                        error "ERROR: pom.xml not found in ${appDir}. Check your repo structure."
                    }
                }
            }
        }

        stage('Static Code Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
                    script {
                        def appDir = "${WORKSPACE}/my-java-cicd-project/java-app"
                        if (fileExists("${appDir}/pom.xml")) {
                            sh """
                                cd ${appDir}
                                mvn sonar:sonar -Dsonar.login=$SONAR_AUTH_TOKEN -Dsonar.host.url=${SONAR_URL} -B
                            """
                        } else {
                            echo "Skipping SonarQube analysis, pom.xml not found."
                        }
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    def appDir = "${WORKSPACE}/my-java-cicd-project/java-app"
                    if (fileExists("${appDir}/Dockerfile")) {
                        sh "docker build -t ${DOCKER_IMAGE} ${appDir}"
                    } else {
                        echo "Skipping Docker build, Dockerfile not found in ${appDir}"
                    }
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {
                        docker.image("${DOCKER_IMAGE}").push()
                    }
                }
            }
        }

        stage('Update Deployment File') {
            steps {
                withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
                    script {
                        def deployFile = "${WORKSPACE}/my-java-cicd-project/java-manifests/deployment.yaml"
                        if (fileExists(deployFile)) {
                            sh """
                                git config user.email "prasannayendluri45@gmail.com"
                                git config user.name "Prasanna Yendluri"
                                sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" ${deployFile}
                                git add ${deployFile}
                                git commit -m "Update deployment image to version ${BUILD_NUMBER}" || true
                                git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
                            """
                        } else {
                            echo "Deployment file not found, skipping update."
                        }
                    }
                }
            }
        }

    }
}
